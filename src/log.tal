( write )

|a0 @File1/vector $2 &success $2 &stat $2 &delete $1 &append $1 &name $2 &length $2 &read $2 &write $2
|b0 @File2/vector $2 &success $2 &stat $2 &delete $1 &append $1 &name $2 &length $2 &read $2 &write $2

|100

@on-reset ( -> )
	now/<generate>
	rss/<generate>
	#010e DEO
	BRK

%u8/mod ( a b -- res ) {
	DIVk MUL SUB }

%u16/mod ( a* b* -- a%b* ) {
	DIV2k MUL2 SUB2 }

(
@|Html )

%html/<lb> { ;ascii/line .File2/write DEO2 }

%html/<ws> { ;ascii/space .File2/write DEO2 }

%html/<comma> { ;ascii/comma .File2/write DEO2 }

%html/<str> ( addr* -- ) {
	DUP2 str/tail OVR2 SUB2 html/<length> }

%html/<length> ( src* length* -- ) {
	.File2/length DEO2
	.File2/write DEO2
	#0001 .File2/length DEO2 }

%html/<open> ( tag* -- ) {
	;ascii/lt .File2/write DEO2
	html/<str>
	;ascii/gt .File2/write DEO2 }

%html/<close> ( tag* -- ) {
	;ascii/lt .File2/write DEO2
	;ascii/slash .File2/write DEO2
	html/<str>
	;ascii/gt .File2/write DEO2 }

%html/<auto> ( str* tag* -- ) {
	DUP2 html/<open>
	SWP2 html/<str>
	html/<close> }

(
@|Now )

@now/<generate> ( -- )
	#150f
	&>l
		DUP now/<parse-year>
		INC GTHk ?&>l
	POP2 JMP2r

@now/<parse-year> ( arv-year -- )
	DUP src-htm-path/make .File2/name DEO2
	#0001 .File2/length DEO2
	STHk src-log-path/<set-year>
	( | parse head )
	#fe src-log-path/<set-month>
	;src-log-path/buf /<parse-head>
	( | search for logs )
	#1a
	&>lp
		#01 SUB DUP src-log-path/<set-month>
		STHkr OVR ;src-log-path/buf /<parse-month>
		DUP ?&>lp
	POP POPr JMP2r

@now/<parse-head> ( year path* -- )
	workarea/<load>
	ORA ?{ JMP2r }
	;workarea/buf html/<str>
	JMP2r

@now/<parse-month> ( year month path* -- )
	workarea/<load>
	ORA ?{ POP2 JMP2r }
	( | h3 month h3 )
	;tag/h3 html/<open>
	( arvelie ) arvelie/make STH2k #0003 html/<length>
	;tag/h3 html/<close>
	html/<lb>
	;tag/article html/<open>
	html/<lb>
	( | h2 gregorian title h2 )
	;tag/h2 html/<open>
	( gregorian ) STH2r arvelie/year-month-day year-month-day/make html/<str>
	html/<ws>
	( title ) ;workarea/buf DUP2 DUP2 str/next STH2k SWP2 INC2 SUB2 html/<length>
	;tag/h2 html/<close>
	( | body )
	STH2r html/<str>
	;tag/article html/<close>
	html/<lb>
	html/<lb>
	JMP2r

(
@|RSS )

@rss/<generate> ( -- )
	;dict/rss-path .File2/name DEO2
	#0001 .File2/length DEO2
	;dict/xml-head html/<str>
	html/<lb>
	;dict/rss-version html/<str>
	html/<lb>
	;tag/channel html/<open>
	html/<lb>
	;dict/title ;tag/title html/<auto>
	;path/url ;tag/link html/<auto>
	;dict/desc ;tag/description html/<auto>
	html/<lb>
	( | body )
	#150f
	&>l
		DUP rss/<parse-year>
		INC GTHk ?&>l
	POP2 ;tag/channel html/<close>
	;tag/rss html/<close>
	JMP2r

@rss/<parse-year> ( arv-year -- )
	STHk src-log-path/<set-year>
	#1a
	&>lp
		#01 SUB DUP src-log-path/<set-month>
		STHkr OVR ;src-log-path/buf /<parse-month>
		DUP ?&>lp
	POP POPr JMP2r

@rss/<parse-month> ( year month path* -- )
	workarea/<load>
	ORA ?{ POP2 JMP2r }
	;tag/item html/<open>
	html/<lb>
	( | link )
	;tag/link html/<open>
	OVR site-htm-path/make html/<str>
	;tag/link html/<close>
	html/<lb>
	( | date )
	;tag/pubdate html/<open>
	arvelie/make arvelie/year-month-day year-month-day/<emit>
	html/<ws>
	;dict/midnight html/<str>
	;tag/pubdate html/<close>
	html/<lb>
	( | title )
	;tag/title html/<open>
	;workarea/buf DUP2 DUP2 str/next STH2k SWP2 INC2 SUB2 html/<length>
	;tag/title html/<close>
	html/<lb>
	;tag/description html/<open>
	;tag/cdata-a html/<str>
	STH2r html/<str>
	;tag/cdata-b html/<str>
	;tag/description html/<close>
	html/<lb>
	;tag/item html/<close>
	html/<lb>
	html/<lb>
	JMP2r

(
@|Stdlib )

@str/<print> ( str* -- )
	LDAk DUP ?{ POP POP2 JMP2r }
	#18 DEO
	INC2 !/<print>

@str/<print-line> ( str* -- )
	LDAk DUP #1f GTH ?{ POP POP2 JMP2r }
	#18 DEO
	INC2 !/<print-line>

@str/next ( str* -- next* )
	&>wn
		LDAk #20 LTH ?{ INC2 !&>wn }
	INC2 JMP2r

@str/tail ( str* -- end* )
	&>w2
		LDAk ?{ JMP2r }
		INC2 !&>w2

(
@|Buffers )

@src-log-path/<set-year> ( year -- )
	DUP #0a DIV [ LIT "0 ] ADD ,&y1 STR
	#0a u8/mod [ LIT "0 ] ADD ,&y2 STR
	JMP2r

@src-log-path/<set-month> ( month -- )
	LIT "a ADD ,&m STR
	JMP2r

	&buf "src/log/ &y1 $1 &y2 $1 &m $1 ".htm 00

@src-htm-path/make ( arv-year -- )
	#00 SWP #07d6 ADD2
	( yyyx ) DUP2 #03e8 DIV2 NIP LIT "0 ADD ,&xyyy STR
	( yyyx ) DUP2 #0064 DIV2 NIP #0a u8/mod LIT "0 ADD ,&yxyy STR
	( yyyx ) DUP2 #000a DIV2 NIP #0a u8/mod LIT "0 ADD ,&yyxy STR
	( yyyx ) #000a u16/mod NIP LIT "0 ADD ,&yyyx STR
	;&buf JMP2r

	&buf "src/htm/
	&xyyy "0
	&yxyy "0
	&yyxy "0
	&yyyx "0 ".htm 00

@site-htm-path/make ( arv-year -- )
	#00 SWP #07d6 ADD2
	( yyyx ) DUP2 #03e8 DIV2 NIP LIT "0 ADD ,&xyyy STR
	( yyyx ) DUP2 #0064 DIV2 NIP #0a u8/mod LIT "0 ADD ,&yxyy STR
	( yyyx ) DUP2 #000a DIV2 NIP #0a u8/mod LIT "0 ADD ,&yyxy STR
	( yyyx ) #000a u16/mod NIP LIT "0 ADD ,&yyyx STR
	;&buf JMP2r

	&buf "https://wiki.xxiivv.com/site/
	&xyyy "0
	&yxyy "0
	&yyxy "0
	&yyyx "0 ".html 00

@workarea/<load> ( path* -- succ* )
	.File1/name DEO2
	#8000 .File1/length DEO2
	;&buf .File1/read DEO2
	.File1/success DEI2 DUP2 ;&buf ADD2 #0000 SWP2 STA2
	JMP2r

(
@|Date )

@arvelie/make ( year month -- str* )
	LIT "A ADD ,&m STR
	DUP #0a DIV [ LIT "0 ] ADD ,&y1 STR
	#0a u8/mod [ LIT "0 ] ADD ,&y2 STR
	;&buf JMP2r
	&buf &y1 $1 &y2 $1 &m $1 "00 00

@arvelie/get-year ( date* -- year* )
	dec/parse #07d6 ADD2 JMP2r

@arvelie/get-month ( char -- res )
	DUP LIT "+ NEQ ?{ POP #1a JMP2r }
	[ LIT "A ] SUB JMP2r

@arvelie/get-doty ( date* -- doty* )
	INC2 INC2 LDAk /get-month STH
	INC2 dec/parse #00 STHr #000e MUL2 ADD2 JMP2r

@arvelie/year-month-day ( date* -- year* month day )
	DUP2 /get-doty SWP2 /get-year !doty-year/year-month-day

@year-month-day/make ( y* m d -- str* )
	( xd ) DUP #0a DIV LIT "0 ADD ,&xd STR
	( dx ) #0a u8/mod LIT "0 ADD ,&dx STR
	( xm ) DUP #0a DIV LIT "0 ADD ,&xm STR
	( mx ) #0a u8/mod LIT "0 ADD ,&mx STR
	( yyyx ) DUP2 #03e8 DIV2 NIP LIT "0 ADD ,&xyyy STR
	( yyyx ) DUP2 #0064 DIV2 NIP #0a u8/mod LIT "0 ADD ,&yxyy STR
	( yyyx ) DUP2 #000a DIV2 NIP #0a u8/mod LIT "0 ADD ,&yyxy STR
	( yyyx ) #000a u16/mod NIP LIT "0 ADD ,&yyyx STR
	;&buf JMP2r
	&buf
	&xyyy "0
	&yxyy "0
	&yyxy "0
	&yyyx "0 "- &xm $1 &mx $1 "- &xd $1 &dx $1 00

@dec/parse ( str* -- dec* )
	LDA2
	( a ) [ LIT "0 ] SUB SWP
	( b ) [ LIT "0 ] SUB #0a MUL ADD #00 SWP JMP2r

@doty-year/year-month-day ( doty* year* -- year* month day )
	,&year STR2
	STH2
	#0c00
	&>l2
		DUP [ LIT2 &year $2 ] ROT year-month/days #00 SWP DUP2 STH2kr GTH2 ?&skip2
		STH2k SUB2r !&continue2
		&skip2 POP2 !{
		&continue2 POP2 INC GTHk ?&>l2 }
	NIP STHr POPr INC ,&year LDR2 SWP2 JMP2r

@year-month-day/dotw ( year* m d -- dotw )
	OVR #01 GTH ?{
		( m < 3 ) SWP2 #0001 SUB2 SWP2 }
	STH2
	( y* y/4* ) DUP2 #02 SFT2
	( y* y/4-y/100* ) OVR2 #0064 DIV2 SUB2
	( y+y/4-y/100+y/400* ) OVR2 #0190 DIV2 ADD2 ADD2
	( y+y/4-y/100+y/400+d* ) #00 STHr ADD2
	( y+y/4-y/100+y/400+d+lut[m]* ) #0000 STHr ;&lut ADD2 LDA ADD2
	( % 7 ) #0007 u16/mod NIP JMP2r

	&lut [ 00 03 02 05 00 03 05 01 04 06 02 04 ]

@year-month-day/<emit> ( year* month day -- )
	OVR2 OVR2 /dotw dotw/<emit>
	html/<comma>
	html/<ws>
	#00 SWP dec/<emit>
	html/<ws>
	month/<emit>
	html/<ws> !dec/<emit>

@year-month/days ( year* month -- days )
	#00 OVR ;&lut ADD2 LDA SWP #01 NEQ ?{
		STH
		DUP2 year/is-leap STHr ADD }
	NIP NIP JMP2r

	&lut [ 1f 1c 1f 1e 1f 1e 1f 1f 1e 1f 1e 1f ]

@year/is-leap ( year* -- bool )
	DUP2 #0190 u16/mod #0000 EQU2 ?&leap
	DUP2 #0064 u16/mod #0000 EQU2 ?&not-leap
	#0003 AND2 #0000 EQU2 JMP2r
	&not-leap POP2 #00 JMP2r
	&leap POP2 #01 JMP2r

@dotw/<emit> ( dotw -- )
	#00 SWP #20 SFT2 ;&lut ADD2 html/<str>
	JMP2r

	&lut [
	"Sun 00 "Mon 00 "Tue 00 "Wed 00
	"Thu 00 "Fri 00 "Sat 00 ]

@month/<emit> ( month -- )
	#00 SWP #20 SFT2 ;&lut ADD2 html/<str>
	JMP2r

	&lut [
	"Jan 00 "Feb 00 "Mar 00 "Apr 00
	"May 00 "Jun 00 "Jul 00 "Aug 00
	"Sep 00 "Oct 00 "Nov 00 "Dec 00 ]

@dec/<emit> ( short* -- )
	[ LIT2r ff00 ]
	&>read
		#000a DIV2k STH2k MUL2 SUB2 STH2r INCr ORAk ?&>read
	POP2
	&>write
		NIP #30 ADD ,&b STR
		;&b .File2/write DEO2
		OVRr ADDr STHkr ?&>write
	POP2r JMP2r
	&b $1

(
@|Assets )

@dict/xml-head "<?xml 20 "version="1.0" 20 "encoding="UTF-8"?> 00
	&rss-version "<rss 20 "version="2.0"> 00
	&title "XXIIVV 00
	&desc "Journal 20 "Logs 00
	&no-picture "000 00
	&midnight "12:00:00 20 "-0000 00
	&rss-path "links/log.xml 00

@path/url "https://wiki.xxiivv.com/ 00
	&diary "media/diary/ 00
	&site "site/ 00
	&ext-jpg ".jpg 00
	&ext-html ".html 00

@ascii/space 20 &line 0a
	&lt "<
	&gt ">
	&equal "=
	&quote ""
	&slash "/
	&comma ",

@tag/html "html 00
	&head "head 00
	&meta "meta 00
	&title "title 00
	&body "body 00
	&nav "nav 00
	&main "main 00
	&br "br 00
	&p "p 00
	&b "b 00
	&ul "ul 00
	&li "li 00
	&a "a 00
	&h2 "h2 00
	&h3 "h3 00
	&article "article 00
	&span "span 00
	&code "code 00
	&figure "figure 00
	&figcaption "figcaption 00
	&channel "channel 00
	&link "link 00
	&description "description 00
	&item "item 00
	&img "img 00
	&src "src 00
	&rss "rss 00
	&pubdate "pubDate 00
	&cdata-a "<![CDATA[ 00
	&cdata-b "]]> 00

@workarea/buf

